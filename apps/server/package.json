{
  "name": "server",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm db:migrate:local && wrangler dev --port 4000 --env-file .env.development",
    "deploy": "pnpm db:migrate && wrangler deploy --secrets-file .env.production",
    "db:migrate:local": "wrangler d1 migrations apply starter --local",
    "db:migrate": "wrangler d1 migrations apply starter --remote",
    "lint": "biome check .",
    "format": "biome check --write .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hono": "^4.7.10",
    "jose": "^6.0.11",
    "zod": "^3.25.28"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@cloudflare/workers-types": "^5.20260717.1",
    "typescript": "^5.8.3",
    "wrangler": "^4.111.0"
  }
}
